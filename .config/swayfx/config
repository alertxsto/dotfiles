include ~/.config/sway/config

blur enable
blur_xray disable
blur_passes 2
blur_radius 3
blur_noise 0.1
smart_corner_radius enable
corner_radius 4
shadows enable
shadows_on_csd enable
shadow_blur_radius 20
shadow_color #0000004B
shadow_inactive_color #0000004B
shadow_offset 0 5
default_dim_inactive 0.0
titlebar_separator disable

for_window [app_id="org.gnome.Nautilus"] border pixel 1
for_window [app_id="Brave-browser"] blur disable
for_window [app_id="firefox"] blur disable
for_window [app_id="mpv"] blur disable
for_window [app_id="imv"] blur disable
for_window [app_id="thunar"] border pixel 1
for_window [app_id="pane-fm"] border pixel 1
